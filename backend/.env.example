# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="BNI Cricket API"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change_this_to_a_very_long_random_secret_key_minimum_32_chars
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgre123
POSTGRES_DB=bni_cricket
POSTGRES_SCHEMA=bni
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgre123@localhost:5432/bni_cricket
SYNC_DATABASE_URL=postgresql://postgres:postgre123@localhost:5432/bni_cricket

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_IMAGES=bni-images
MINIO_BUCKET_VIDEOS=bni-videos
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000   # public base URL for presigned URLs

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_EMAIL=admin@bnicricket.com
